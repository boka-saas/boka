---
import { formatPrice } from "@/lib/businesses.js";
import { Clock, Scissors } from "@lucide/astro";

interface Props {
	business: {
		services: Array<{ name: string; price: number; duration?: string }>;
	};
}

const { business } = Astro.props;
---

<section id="prices" class="business-section">
  <div class="site-container">
    <div class="mx-auto mb-12 max-w-2xl text-center">
      <p class="mb-3 text-xs font-medium uppercase tracking-[0.14em] opacity-60">
        Services
      </p>
      <h2 class="business-section-title font-brand text-3xl md:text-4xl">
        Prices
      </h2>
      <p class="mt-3 opacity-75">
        Transparent pricing, no surprises.
      </p>
    </div>

    <div class="mx-auto grid max-w-3xl gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        business.services.map((service) => (
          <div class="business-card rounded-2xl p-5 transition-all duration-300 hover:-translate-y-1 hover:shadow-md">
            <div class="business-service-icon mb-4 flex h-10 w-10 items-center justify-center rounded-xl">
              <Scissors size={20} />
            </div>
            <h3 class="business-service-name text-base font-semibold">
              {service.name}
            </h3>
            {service.duration && (
              <p class="business-service-duration mt-1 inline-flex items-center gap-1 text-xs">
                <Clock size={12} /> {service.duration}
              </p>
            )}
            <p class="business-service-price mt-4 font-brand text-2xl">
              {formatPrice(service.price)}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
