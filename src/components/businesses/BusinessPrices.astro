---
import { formatPrice } from "@/lib/businesses.js";
import { Clock, Scissors } from "@lucide/astro";

interface Props {
	business: {
		services: Array<{ name: string; price: number; duration?: string }>;
	};
}

const { business } = Astro.props;
---

<section id="prices" class="py-16 md:py-24">
  <div class="site-container">
    <div class="mx-auto mb-12 max-w-2xl text-center">
      <p class="mb-3 text-xs font-medium uppercase tracking-[0.14em] text-neutral-400 dark:text-neutral-500">
        Services
      </p>
      <h2 class="font-brand text-3xl text-neutral-800 dark:text-neutral-100 md:text-4xl">
        Prices
      </h2>
      <p class="mt-3 text-neutral-600 dark:text-neutral-300">
        Transparent pricing, no surprises.
      </p>
    </div>

    <div class="mx-auto grid max-w-3xl gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        business.services.map((service) => (
          <div class="business-card rounded-2xl p-5 transition-all duration-300 hover:-translate-y-1 hover:shadow-md">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-[var(--business-primary)]/10 text-[var(--business-primary)]">
              <Scissors size={20} />
            </div>
            <h3 class="text-base font-semibold text-neutral-800 dark:text-neutral-100">
              {service.name}
            </h3>
            {service.duration && (
              <p class="mt-1 inline-flex items-center gap-1 text-xs text-neutral-500 dark:text-neutral-400">
                <Clock size={12} /> {service.duration}
              </p>
            )}
            <p class="business-service-price mt-4 font-brand text-2xl">
              {formatPrice(service.price)}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
