---
import { Moon, SunMedium } from "@lucide/astro";

interface Props {
	business: {
		slug: string;
		name: string;
		logo: string;
		theme: {
			primary: string;
			accent: string;
			surface: string;
			surfaceDark: string;
			text: string;
			textDark: string;
		};
	};
}

const { business } = Astro.props;

const toggleGradient = `background: linear-gradient(to bottom, color-mix(in srgb, ${business.theme.primary} 75%, white), ${business.theme.primary});`;
---

<header class="business-header">
  <div class="site-container">
    <div class="business-header-inner flex items-center justify-between h-14 rounded-2xl px-4 sm:px-5">
      <a
        href={`/businesses/${business.slug}`}
        class="flex items-center gap-3"
        style={`color: var(--business-text);`}
      >
        <img
          src={business.logo}
          alt={`${business.name} logo`}
          class="h-9 w-9 rounded-xl object-cover"
          onerror={`this.style.display='none'; this.nextElementSibling.style.display='flex'`}
        />
        <span class="hidden text-base font-semibold sm:inline">
          {business.name}
        </span>
      </a>

      <div class="flex items-center gap-2 sm:gap-4">
        <nav class="hidden items-center gap-1 text-sm font-medium sm:flex">
          <a href="#prices" class="business-nav-link rounded-lg px-3 py-2">
            Prices
          </a>
          <a href="#booking" class="business-nav-link rounded-lg px-3 py-2">
            Book
          </a>
          <a href="#contact" class="business-nav-link rounded-lg px-3 py-2">
            Contact
          </a>
        </nav>

        <button
          type="button"
          id="businessDarkToggle"
          aria-label="Toggle dark mode"
          class="relative flex h-9 items-center gap-1.5 rounded-full border-[0.5px] px-2 transition-all duration-200 hover:shadow-md hover:scale-105 active:scale-95"
          style={`border-color: color-mix(in srgb, var(--business-primary) 25%, transparent); background-color: var(--business-surface);`}
        >
          <div
            class="flex h-6 w-6 flex-shrink-0 items-center justify-center overflow-hidden rounded-full border-[0.5px]"
            style={`${toggleGradient} border-color: color-mix(in srgb, ${business.theme.primary} 60%, white); box-shadow: 0px 2px 3px 0 color-mix(in srgb, ${business.theme.primary} 30%, transparent);`}
          >
            <SunMedium class="dark-hidden h-4 w-4 text-white transition duration-200" />
            <Moon class="dark-visible hidden h-4 w-4 text-white transition duration-200" />
          </div>
          <span class="hidden text-sm sm:inline" style={`color: var(--business-text);`}>
            <span class="dark-hidden">Light</span>
            <span class="dark-visible hidden">Dark</span>
          </span>
        </button>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  (function () {
    const toggle = document.getElementById('businessDarkToggle');
    if (!toggle) return;

    const sun = toggle.querySelector('.dark-hidden');
    const moon = toggle.querySelector('.dark-visible');
    const labelLight = toggle.querySelector('span > .dark-hidden');
    const labelDark = toggle.querySelector('span > .dark-visible');

    function updateIcons() {
      const isDark = document.documentElement.classList.contains('dark');
      if (sun) sun.classList.toggle('hidden', isDark);
      if (moon) moon.classList.toggle('hidden', !isDark);
      if (labelLight) labelLight.classList.toggle('hidden', isDark);
      if (labelDark) labelDark.classList.toggle('hidden', !isDark);
    }

    updateIcons();

    toggle.addEventListener('click', () => {
      const isDark = document.documentElement.classList.contains('dark');
      if (isDark) {
        document.documentElement.classList.remove('dark');
        localStorage.removeItem('dark_mode');
      } else {
        document.documentElement.classList.add('dark');
        localStorage.setItem('dark_mode', 'true');
      }
      updateIcons();
    });

    const observer = new MutationObserver(updateIcons);
    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['class'],
    });
  })();
</script>
