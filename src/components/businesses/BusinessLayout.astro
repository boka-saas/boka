---
import BusinessFooter from "@/components/businesses/BusinessFooter.astro";
import BusinessHeader from "@/components/businesses/BusinessHeader.astro";
import Meta from "@/layouts/Meta.astro";
import "../../styles/global.css";
import "../../styles/business.css";

interface Props {
	business: {
		slug: string;
		name: string;
		category: string;
		tagline: string;
		description: string;
		logo: string;
		theme: {
			name: string;
			source: string;
			bg: string;
			bgDark: string;
			surface: string;
			surfaceDark: string;
			text: string;
			textDark: string;
			primary: string;
			primaryStrong: string;
			accent: string;
		};
		contact: {
			address: string;
			phone: string;
			hours: Record<string, string>;
		};
		services: Array<{ name: string; price: number; duration?: string }>;
		bookingUrl: string;
	};
}

const { business } = Astro.props;

const themeStyle = [
	`--business-bg: ${business.theme.bg};`,
	`--business-bg-dark: ${business.theme.bgDark};`,
	`--business-surface: ${business.theme.surface};`,
	`--business-surface-dark: ${business.theme.surfaceDark};`,
	`--business-text: ${business.theme.text};`,
	`--business-text-dark: ${business.theme.textDark};`,
	`--business-primary: ${business.theme.primary};`,
	`--business-primary-strong: ${business.theme.primaryStrong};`,
	`--business-accent: ${business.theme.accent};`,
].join(" ");
---

<!doctype html>
<html lang="en">
  <head>
    <Meta
      title={business.name}
      description={business.tagline}
      url={`${Astro.site ?? ""}businesses/${business.slug}`}
    />

    <!-- Dark-mode boot script: read persisted preference before first paint. -->
    <script is:inline>
      if (typeof Storage !== 'undefined') {
        if (
          localStorage.getItem('dark_mode') &&
          localStorage.getItem('dark_mode') == 'true'
        ) {
          document.documentElement.classList.add('dark');
        }
      }
    </script>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="antialiased max-w-full overflow-x-hidden">
    {/* Top background grid, tinted with the business primary color. */}
    <svg
      aria-hidden="true"
      class="business-top-bg pointer-events-none absolute top-[-10%] inset-0 -z-10 size-full h-[45%] fill-current stroke-current [mask-image:linear-gradient(to_bottom,_#ffffffad,_transparent)]"
    >
      <defs>
        <pattern id={`business-grid-${business.slug}`} width="12" height="12" patternUnits="userSpaceOnUse" x="-1" y="-1">
          <path d="M.5 12V.5H12" fill="none" stroke-dasharray="0"></path>
        </pattern>
      </defs>
      <rect width="100%" height="100%" stroke-width="0" fill={`url(#business-grid-${business.slug})`}></rect>
    </svg>

    <article
      class="business-page min-h-screen"
      style={themeStyle}
    >
      <BusinessHeader business={business} />
      <main class="pt-24 md:pt-28">
        <slot />
      </main>
      <BusinessFooter business={business} />
    </article>
  </body>
</html>
