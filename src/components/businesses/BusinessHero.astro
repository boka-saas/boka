---
import { formatPrice } from "@/lib/businesses.js";
import { ArrowRight, MapPin } from "@lucide/astro";

interface Props {
	business: {
		name: string;
		category: string;
		tagline: string;
		description: string;
		bookingUrl: string;
		contact: {
			address: string;
		};
		services: Array<{ name: string; price: number }>;
		image?: string;
	};
}

const { business } = Astro.props;
const lowestPrice = Math.min(...business.services.map((s) => s.price));
---

<section class="business-hero py-16 md:py-24">
  <div class="site-container">
    <div class="mx-auto max-w-2xl text-center">
      {
        business.image && (
          <div class="mb-6 flex justify-center">
            <div class="business-photo-ring h-24 w-24 overflow-hidden rounded-full p-1 md:h-32 md:w-32">
              <img
                src={business.image}
                alt={`${business.name} shop photo`}
                width={128}
                height={128}
                loading="eager"
                decoding="async"
                class="h-full w-full rounded-full object-cover"
              />
            </div>
          </div>
        )
      }

      <p class="business-hero-eyebrow mb-4 inline-flex items-center gap-2 rounded-full px-3 py-1 text-xs font-medium">
        <MapPin size={14} />
        {business.contact.address}
      </p>

      <p class="business-hero-category mb-3 inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-semibold">
        {business.category}
      </p>

      <h1 class="business-hero-title font-brand text-4xl leading-tight md:text-5xl lg:text-6xl">
        {business.name}
      </h1>

      <p class="business-hero-tagline mt-4 text-xl font-medium md:text-2xl">
        {business.tagline}
      </p>

      <p class="business-hero-description mt-4 text-base leading-relaxed md:text-lg">
        {business.description}
      </p>

      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a href="#booking" class="business-button inline-flex items-center gap-2 rounded-xl px-6 py-3 text-sm font-medium">
          Book now <ArrowRight size={16} />
        </a>
        <a href="#prices" class="business-button-outline inline-flex items-center gap-2 rounded-xl px-6 py-3 text-sm font-medium">
          See prices from {formatPrice(lowestPrice)}
        </a>
      </div>
    </div>
  </div>
</section>
