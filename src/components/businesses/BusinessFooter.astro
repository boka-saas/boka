---
import { CalendarCheck } from "@lucide/astro";

interface Props {
	business: {
		name: string;
		category: string;
		contact: {
			address: string;
			phone: string;
		};
		bookingUrl: string;
	};
}

const { business } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer class="business-footer mt-8 border-t border-dashed py-12 md:py-16">
  <div class="site-container">
    <div class="flex flex-col items-start justify-between gap-8 md:flex-row md:items-center">
      <div class="max-w-sm">
        <p class="text-lg font-semibold">
          {business.name}
        </p>
        <p class="business-footer-text mt-1 text-sm">
          {business.category}
        </p>
        <p class="business-footer-text mt-3 text-sm">
          {business.contact.address}
        </p>
        <p class="business-footer-text text-sm">
          <a
            href={`tel:${business.contact.phone.replace(/\s/g, "")}`}
            class="business-contact-link transition-colors"
          >
            {business.contact.phone}
          </a>
        </p>
      </div>

      <div class="flex flex-col items-start gap-3 md:items-end">
        <a
          href={business.bookingUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="business-button inline-flex items-center gap-2 rounded-xl px-6 py-3 text-sm font-medium"
        >
          <CalendarCheck size={16} />
          Book now
        </a>
        <p class="business-footer-text text-xs">
          © {currentYear} {business.name}. All rights reserved.
        </p>
      </div>
    </div>
  </div>
</footer>
