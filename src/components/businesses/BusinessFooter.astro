---
interface Props {
	business: {
		name: string;
		contact: {
			address: string;
			phone: string;
		};
		bookingUrl: string;
	};
}

const { business } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer class="business-footer">
  <div class="site-container">
    <div class="flex flex-col items-center justify-between gap-6 py-10 text-center sm:flex-row sm:text-left">
      <div class="max-w-sm">
        <p class="text-lg font-semibold">{business.name}</p>
        <p class="mt-1 text-sm opacity-80">{business.contact.address}</p>
        <p class="mt-1 text-sm opacity-80">
          <a href={`tel:${business.contact.phone.replace(/\s/g, "")}`}>
            {business.contact.phone}
          </a>
        </p>
      </div>

      <div class="flex flex-col items-center gap-3 sm:items-end">
        <a href={business.bookingUrl} target="_blank" class="business-button">
          Book now
        </a>
        <p class="text-xs opacity-60">
          © {currentYear} {business.name}. All rights reserved.
        </p>
      </div>
    </div>
  </div>
</footer>
