---
import { CalendarCheck } from "@lucide/astro";

interface Props {
	business: {
		name: string;
		category: string;
		contact: {
			address: string;
			phone: string;
		};
		bookingUrl: string;
	};
}

const { business } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer class="mt-8 border-t border-dashed border-primary/15 py-12 dark:border-primary-dark/15 md:py-16">
  <div class="site-container">
    <div class="flex flex-col items-start justify-between gap-8 md:flex-row md:items-center">
      <div class="max-w-sm">
        <p class="text-lg font-semibold text-neutral-800 dark:text-neutral-100">
          {business.name}
        </p>
        <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">
          {business.category}
        </p>
        <p class="mt-3 text-sm text-neutral-500 dark:text-neutral-400">
          {business.contact.address}
        </p>
        <p class="text-sm text-neutral-500 dark:text-neutral-400">
          <a
            href={`tel:${business.contact.phone.replace(/\s/g, "")}`}
            class="business-contact-link transition-colors"
          >
            {business.contact.phone}
          </a>
        </p>
      </div>

      <div class="flex flex-col items-start gap-3 md:items-end">
        <a
          href={business.bookingUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="business-button inline-flex items-center gap-2 rounded-xl px-6 py-3 text-sm font-medium"
        >
          <CalendarCheck size={16} />
          Book now
        </a>
        <p class="text-xs text-neutral-400 dark:text-neutral-500">
          © {currentYear} {business.name}. All rights reserved.
        </p>
      </div>
    </div>
  </div>
</footer>
