---
import AnimatedText from "@/components/ui/AnimatedText.astro";
import Badge from "@/components/ui/Badge.astro";
import Button from "@/components/ui/Button.astro";
import PhoneFrame from "@/components/ui/PhoneFrame.astro";
import { siteConfig } from "@/config/site";
import { ArrowRight, CalendarCheck } from "@lucide/astro";
---

<div
  class="relative z-20 mx-auto mt-16 w-full px-4 site-container md:mt-18 lg:mt-32 xl:px-0"
>
  <div
    class="relative mb-16 flex w-full flex-col items-center justify-between px-4 md:flex-row md:items-start"
  >
    <div
      class="relative w-full text-center sm:text-left md:w-1/2 md:max-w-[540px]"
    >
      <h1 class="mb-4">
        <AnimatedText
          content="Get booked. Get paid. Grow your business."
          delay={0.1}
          duration={0.5}
          stagger={0.08}
          class="text-pri text-4xl leading-tight font-brand md:text-4xl lg:text-6xl"
        />
      </h1>

      <div class="mb-6">
        <AnimatedText
          content="Boka brings online bookings, payments, automated reminders, staff availability, custom websites, and business insights into one simple platform for local service businesses."
          delay={0.3}
          duration={0.5}
          stagger={0.015}
          class="text-base leading-relaxed text-neutral-600 dark:text-neutral-300"
        />
      </div>

      <div
        class="flex flex-wrap justify-center gap-3 sm:justify-start"
        data-aos="fade-up-sm"
        data-aos-delay="600"
        data-aos-duration="500"
        data-aos-once="true"
      >
        <Button url={siteConfig.links.barberDemo} type="fill" target="_blank">
          <CalendarCheck size={16} /> View barber demo
        </Button>
        <Button url={siteConfig.links.dashboardDemo} target="_blank">
          Business dashboard <ArrowRight size={16} />
        </Button>
      </div>

      <div
        class="mt-6 flex flex-wrap justify-center gap-2 sm:justify-start"
        data-aos="fade-up-xs"
        data-aos-delay="100"
        data-aos-duration="500"
        data-aos-once="true"
      >
        <Badge variant="primary">For barbers & salons</Badge>
        <Badge variant="accent">Booking + payments</Badge>
      </div>
    </div>

    <div
      class="relative mt-16 flex w-full flex-col items-center md:mt-0 md:w-1/2 md:pl-10"
      data-aos="fade-up-sm"
      data-aos-delay="300"
      data-aos-duration="800"
      data-aos-once="true"
    >
      <a
        href={siteConfig.links.dashboardDemo}
        target="_blank"
        rel="noopener noreferrer"
        class="group hero-preview-link block w-full max-w-[360px]"
        aria-label="Open live dashboard demo in a new tab"
      >
        <PhoneFrame className="hero-preview-frame w-full">
          <div
            class="relative overflow-hidden bg-bg-secondary dark:bg-neutral-900"
          >
            <img
              src="/assets/boka/boka-dashboard-mobile.png"
              alt="Boka dashboard preview showing booking and revenue insights"
              loading="eager"
              width="1000"
              height="1514"
              class="h-auto w-full object-cover object-[top_center]"
            />
            <div
              class="pointer-events-none absolute inset-0 flex items-center justify-center bg-neutral-900/0 transition-colors duration-300 group-hover:bg-neutral-900/20"
            >
              <span
                class="inline-flex items-center gap-2 rounded-full border border-white/60 bg-white/90 px-4 py-2 text-sm font-medium text-neutral-800 opacity-0 shadow-sm backdrop-blur transition-opacity duration-300 group-hover:opacity-100 dark:border-neutral-700/70 dark:bg-neutral-900/85 dark:text-neutral-100"
              >
                Open live demo <ArrowRight size={16} />
              </span>
            </div>
          </div>
        </PhoneFrame>
      </a>
      <div class="mt-3 inline-flex items-center gap-2 rounded-full border border-primary/15 bg-white/90 px-3 py-1 text-xs font-medium text-neutral-700 shadow-sm backdrop-blur dark:border-neutral-700/70 dark:bg-neutral-900/85 dark:text-neutral-200">
        <span class="hero-live-dot relative h-2 w-2 rounded-full bg-emerald-500"></span>
        Live business demo
      </div>
    </div>
  </div>
</div>

<style>
  .hero-preview-frame {
    transition:
      transform 300ms cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 300ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .hero-preview-link:hover .hero-preview-frame,
  .hero-preview-link:focus-visible .hero-preview-frame {
    transform: scale(1.02);
    box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.25);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-preview-frame {
      transition: none !important;
    }

    .hero-preview-link:hover .hero-preview-frame,
    .hero-preview-link:focus-visible .hero-preview-frame {
      transform: none;
    }
  }

  .hero-live-dot::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 9999px;
    background: currentColor;
    color: rgb(16, 185, 129);
    animation: hero-live-ping 2s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  @keyframes hero-live-ping {
    0% {
      opacity: 0.7;
      transform: scale(1);
    }
    80%,
    100% {
      opacity: 0;
      transform: scale(3);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-live-dot::before {
      animation: none !important;
    }
  }
</style>
