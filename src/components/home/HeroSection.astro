---
import Button from "@/components/ui/Button.astro";
import Badge from "@/components/ui/Badge.astro";
import AnimatedText from "@/components/ui/AnimatedText.astro";
import BrowserFrame from "@/components/ui/BrowserFrame.astro";
import { siteConfig } from "@/config/site";
import { ArrowRight, CalendarCheck, LayoutDashboard } from "@lucide/astro";
---

<div class="relative z-20 mx-auto mt-16 w-full px-4 site-container md:mt-18 lg:mt-32 xl:px-0">
  <div class="relative mb-16 flex w-full flex-col items-center justify-between px-4 md:flex-row">
    <div class="relative w-full text-center sm:-mt-8 sm:text-left md:w-1/2 md:max-w-[540px]">
      <div
        class="mb-6 flex flex-wrap justify-center gap-2 sm:justify-start"
        data-aos="fade-up-xs"
        data-aos-delay="100"
        data-aos-duration="500"
        data-aos-once="true"
      >
        <Badge variant="primary">For barbers & salons</Badge>
        <Badge variant="accent">Booking + payments</Badge>
      </div>

      <h1 class="mb-4">
        <AnimatedText
          content="Get booked. Get paid. Grow your business."
          delay={0.1}
          duration={0.5}
          stagger={0.08}
          class="text-pri text-4xl leading-tight font-brand md:text-4xl lg:text-6xl"
        />
      </h1>

      <div class="mb-6">
        <AnimatedText
          content="Boka brings online bookings, Stripe payments, automated reminders, staff availability, custom websites, and business insights into one simple platform for local service businesses."
          delay={0.3}
          duration={0.5}
          stagger={0.015}
          class="text-base leading-relaxed text-neutral-600 dark:text-neutral-300"
        />
      </div>

      <div
        class="flex flex-wrap justify-center gap-3 sm:justify-start"
        data-aos="fade-up-sm"
        data-aos-delay="600"
        data-aos-duration="500"
        data-aos-once="true"
      >
        <Button url={siteConfig.links.barberDemo} type="fill" target="_blank">
          <CalendarCheck size={16} /> View barber demo
        </Button>
        <Button url={siteConfig.links.dashboardDemo} target="_blank">
          Business dashboard <ArrowRight size={16} />
        </Button>
      </div>
    </div>

    <div
      class="relative mt-16 w-full justify-end md:flex md:w-1/2 md:translate-y-4 md:pl-10 md:mt-0 xl:translate-y-0"
      data-aos="fade-up-sm"
      data-aos-delay="300"
      data-aos-duration="800"
      data-aos-once="true"
    >
      <BrowserFrame url="boka.app/dashboard" className="w-full">
        <div class="relative overflow-hidden bg-bg-secondary dark:bg-neutral-900">
          <img
            src="/assets/boka/boka-dashboard.png"
            alt="Boka dashboard preview showing booking and revenue insights"
            loading="eager"
            width="1280"
            height="1044"
            class="h-[300px] w-full object-cover object-top md:h-[350px]"
          />
          <div class="absolute left-4 top-4 inline-flex items-center gap-2 rounded-full border border-white/60 bg-white/90 px-3 py-1 text-xs font-medium text-neutral-700 shadow-sm backdrop-blur dark:border-neutral-700/70 dark:bg-neutral-900/85 dark:text-neutral-200">
            <span class="hero-live-dot relative h-2 w-2 rounded-full bg-emerald-500"></span>
            Live business overview
          </div>
          <div class="absolute bottom-4 right-4 hidden items-center gap-2 rounded-xl border border-primary/15 bg-white/92 px-3 py-2 text-sm font-medium text-neutral-700 shadow-sm backdrop-blur dark:border-neutral-700 dark:bg-neutral-900/90 dark:text-neutral-200 sm:inline-flex">
            <LayoutDashboard size={16} class="text-primary" />
            Bookings, revenue, staff
          </div>
        </div>
      </BrowserFrame>
    </div>
  </div>
</div>

<style>
  .hero-live-dot::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 9999px;
    background: currentColor;
    color: rgb(16, 185, 129);
    animation: hero-live-ping 2s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  @keyframes hero-live-ping {
    0% {
      opacity: 0.7;
      transform: scale(1);
    }
    80%,
    100% {
      opacity: 0;
      transform: scale(3);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-live-dot::before {
      animation: none !important;
    }
  }
</style>
