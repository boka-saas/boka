---
import Logo from "@/components/ui/Logo.astro";
import ToTop from "@/components/widgets/ToTop.astro";
import { siteConfig, socialLinks } from "@/config/site.js";

const currentYear = new Date().getFullYear();

const footerGroups = [
  {
    title: "Product",
    links: [
      { name: "Features", url: "/features" },
      { name: "Pricing", url: "/pricing" },
      { name: "Start free trial", url: siteConfig.links.trial },
    ],
  },
  {
    title: "Demos",
    links: [
      { name: "Barber booking site", url: siteConfig.links.barberDemo },
      { name: "Business dashboard", url: siteConfig.links.dashboardDemo },
    ],
  },
  {
    title: "Company",
    links: [
      { name: "About", url: "/about" },
      { name: "Contact", url: "/contact" },
    ],
  },
];
---

<section class="mt-20 border-t border-dashed border-primary/15 text-gray-700 dark:border-primary-dark/15 md:mt-48">
  <div class="container mx-auto max-w-7xl px-7 py-12 md:py-16">
    <div class="mb-12 flex flex-col gap-8 md:flex-row md:items-start md:justify-between">
      <div class="max-w-sm">
        <Logo />
        <p class="mt-4 text-sm leading-relaxed text-neutral-500 dark:text-neutral-400">
          Boka helps barbers, salons, and beauty professionals take bookings, payments, reminders, and business insights from one calm workspace.
        </p>
      </div>

      <div class="grid grid-cols-2 gap-8 sm:grid-cols-3 md:gap-12">
        {footerGroups.map((group) => (
          <div>
            <h4 class="mb-4 text-sm font-semibold text-neutral-800 dark:text-neutral-200">{group.title}</h4>
            <ul class="space-y-3">
              {group.links.map((link) => (
                <li>
                  <a
                    href={link.url}
                    target={link.url.startsWith("http") ? "_blank" : "_self"}
                    class="text-sm text-neutral-500 transition-colors duration-200 hover:text-primary dark:text-neutral-400 dark:hover:text-primary-light"
                  >
                    {link.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <div class="flex flex-col items-center justify-between gap-4 border-t border-dashed border-primary/10 pt-8 dark:border-primary-dark/10 sm:flex-row">
      <p class="text-sm text-neutral-400 dark:text-neutral-500">
        © {currentYear}
        <a href={siteConfig.url || " "} target="_blank" class="transition-colors hover:text-primary dark:hover:text-primary-light">{siteConfig.author || " "}</a>.
        All rights reserved.
      </p>

      <div class="flex items-center gap-4">
        <span class="inline-flex items-center gap-2 text-xs text-neutral-400 dark:text-neutral-500">
          <span class="inline-flex items-center gap-1.5 rounded-full border border-dashed border-primary/30 px-2 py-0.5 text-primary/80">
            <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
            Booking, payments, websites
          </span>
        </span>
        {socialLinks.length > 0 && (
          <span class="inline-flex justify-center space-x-4">
            {socialLinks.map((social) => (
              <a
                href={social.url}
                target="_blank"
                class="footer-social-icon-link text-neutral-400 transition-colors duration-200 hover:text-primary dark:text-neutral-500 dark:hover:text-primary-light"
                title={social.name}
              >
                <span class="sr-only">{social.name}</span>
                <div class="footer-social-icon">
                  <Fragment set:html={social.icon} />
                </div>
              </a>
            ))}
          </span>
        )}
      </div>
    </div>
  </div>
</section>

<ToTop />

<style is:global>
  .footer-social-icon {
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .footer-social-icon svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
  }
</style>
