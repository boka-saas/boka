---
import PageHeader from "@/components/elements/PageHeader.astro";
import BrowserFrame from "@/components/ui/BrowserFrame.astro";
import Button from "@/components/ui/Button.astro";
import { siteConfig } from "@/config/site";
import Layout from "@/layouts/Layout.astro";
import {
	ArrowRight,
	BadgePoundSterling,
	Bell,
	CalendarCheck,
	Check,
	CreditCard,
	Globe,
	Users,
} from "@lucide/astro";

const featureModules = [
	{
		icon: CalendarCheck,
		title: "Online booking that stays open after you close",
		desc: "Clients can browse services, choose a time, and book from their phone without waiting for a reply. Boka keeps booking friction low for both regulars and first-time visitors.",
		points: [
			"Mobile-friendly booking flow",
			"Service and staff selection",
			"Availability connected to your schedule",
			"Works for barbers, salons, beauty, and aesthetics",
		],
	},
	{
		icon: CreditCard,
		title: "Payments built into the appointment flow",
		desc: "Take money upfront, collect deposits, or let clients pay in store. Stripe support keeps the checkout familiar while giving the business more control over cash flow.",
		points: [
			"Stripe-powered online payments",
			"Deposit or full-payment options",
			"Cleaner handoff from booking to checkout",
		],
	},
	{
		icon: BadgePoundSterling,
		title: "A dashboard owners can actually read",
		desc: "Boka gives owners a clear view of appointments, revenue, and business activity without turning simple questions into spreadsheet work.",
		points: [
			"Revenue overview",
			"Appointment activity",
			"Service performance signals",
			"Daily management view",
		],
	},
	{
		icon: Globe,
		title: "A custom website connected to bookings",
		desc: "Your site should look professional and move clients toward the right action. Boka websites present services, brand, and booking together instead of sending clients across disconnected tools.",
		points: [
			"Custom website",
			"Hosted pages",
			"Service-led content",
			"Booking CTA close to the client decision",
		],
	},
	{
		icon: Users,
		title: "Staff availability and appointment control",
		desc: "Set weekly availability, manage team schedules, and keep appointments organized as the business grows beyond one person.",
		points: [
			"Weekly availability",
			"Staff schedule setup",
			"Appointment management",
			"Designed for multi-service teams",
		],
	},
	{
		icon: Bell,
		title: "Automated alerts that reduce admin",
		desc: "SMS and email reminders help clients remember their appointments and give owners fewer manual follow-ups to chase.",
		points: [
			"SMS / Email reminders",
			"Calender integration",
			"Appointment updates",
			"Less manual client chasing",
		],
	},
];
---

<Layout
  title="Features - Boka"
  description="Online booking, payments, reminders, custom websites, staff management, and business insights for barbers, salons, and beauty professionals."
>
  <section class="site-container my-12">
    <PageHeader
      title="Everything your service business needs to run bookings online"
      description="Boka combines the client-facing booking experience with the internal tools owners need to manage appointments, payments, staff, reminders, and growth."
    />
  </section>

  <section class="site-container pb-8 md:pb-16" data-aos="fade-up-xs" data-aos-once="true">
    <BrowserFrame url="boka.app/dashboard">
      <img
        src="/assets/boka/boka-dashboard.png"
        alt="Boka business dashboard"
        loading="eager"
        width="1280"
        height="1044"
        class="h-[360px] w-full object-cover object-top md:h-[560px]"
      />
    </BrowserFrame>
  </section>

  {featureModules.map((mod, i) => (
    <section class="site-container py-14 md:py-20">
      <div class={`grid items-center gap-8 md:gap-14 ${i % 2 === 1 ? "lg:grid-cols-[1fr_0.85fr]" : "lg:grid-cols-[0.85fr_1fr]"}`}>
        <div class={i % 2 === 1 ? "lg:order-2" : ""} data-aos="fade-up-sm" data-aos-once="true">
          <div class="mb-6 flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10">
            <mod.icon class="h-6 w-6 text-primary" />
          </div>
          <h2 class="mb-4 font-brand text-2xl text-neutral-800 dark:text-neutral-100 md:text-3xl">{mod.title}</h2>
          <p class="mb-6 leading-relaxed text-neutral-600 dark:text-neutral-300">{mod.desc}</p>
        </div>

        <div class={i % 2 === 1 ? "lg:order-1" : ""} data-aos="fade-up-sm" data-aos-delay="150" data-aos-once="true">
          <div class="rounded-2xl border border-primary/10 bg-bg-secondary p-6 dark:border-neutral-700 dark:bg-bg-secondary-dark">
            <div class="mb-5 flex items-center justify-between border-b border-dashed border-neutral-200 pb-4 dark:border-neutral-700">
              <span class="text-xs font-medium uppercase tracking-[0.14em] text-neutral-400">Boka module</span>
              <mod.icon class="h-5 w-5 text-primary" />
            </div>
            <div class="space-y-3">
              {mod.points.map((point, pointIndex) => (
                <div class="flex items-center gap-3 rounded-xl border border-primary/10 bg-bg-primary/50 px-4 py-3 dark:border-neutral-700 dark:bg-neutral-900/40">
                  <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-xs font-semibold text-primary">
                    {pointIndex + 1}
                  </span>
                  <span class="text-sm font-medium text-neutral-700 dark:text-neutral-200">{point}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  ))}

  <div class="my-4 w-full border-b border-dashed border-neutral-200 site-container dark:border-neutral-700"></div>

  <section class="site-container py-16 md:py-24" data-aos="fade-up-xs" data-aos-once="true">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="mb-4 font-brand text-3xl text-neutral-800 dark:text-neutral-100 md:text-4xl">See Boka in context</h2>
      <p class="mb-8 leading-relaxed text-neutral-600 dark:text-neutral-300">
        Explore the client booking demo, then review pricing when you are ready to map Boka to your business.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <Button url={siteConfig.links.barberDemo} type="fill" className="px-8 py-3 text-lg" target="_blank">
          View barber demo <ArrowRight size={18} />
        </Button>
        <Button url="/pricing" className="px-8 py-3 text-lg">
          View pricing
        </Button>
      </div>
    </div>
  </section>
</Layout>
