---
import Layout from "@/layouts/Layout.astro";
import HeroSection from "@/components/home/HeroSection.astro";
import SectionHeader from "@/components/elements/SectionHeader.astro";
import Pricing from "@/components/sections/Pricing.astro";
import FAQ from "@/components/sections/FAQ.astro";
import Button from "@/components/ui/Button.astro";
import BrowserFrame from "@/components/ui/BrowserFrame.astro";
import { siteConfig } from "@/config/site";
import {
  ArrowRight,
  BadgePoundSterling,
  Bell,
  CalendarCheck,
  ChartNoAxesColumnIncreasing,
  CircleCheck,
  Clock3,
  CreditCard,
  Globe,
  MapPin,
  MessageCircle,
  Scissors,
  Search,
  Smartphone,
  TrendingUp,
  Users,
} from "@lucide/astro";

const proofPoints = [
  { value: "24/7", label: "client self-booking" },
  { value: "1 month", label: "free trial" },
  { value: "Online", label: "payment-ready" },
  { value: "Web + Mobile", label: "site + dashboard" },
];

const problems = [
  {
    icon: Clock3,
    title: "After-hours bookings get missed",
    desc: "Clients often decide at night, between meetings, or on their commute. Boka lets them book when the intent is fresh.",
  },
  {
    icon: Bell,
    title: "No-shows quietly drain revenue",
    desc: "Automated email reminders and calender integration helps clients remember appointments before empty slots turn into lost income.",
  },
  {
    icon: ChartNoAxesColumnIncreasing,
    title: "Business performance is hard to read",
    desc: "Bookings, payments, staff, and revenue belong in one dashboard so you can make decisions quickly.",
  },
];

const whyBokaMatters = [
  {
    icon: Search,
    title: "Be easier to find online",
    desc: "With highly optimised SEO friendly websites to ensure you rank first, every time. Turning local interest into foot traffic.",
  },
  {
    icon: Users,
    title: "Value your customer",
    desc: "Allow the valued regulars and new customes to skip the queue, save the waiting around.",
  },
  {
    icon: Smartphone,
    title: "Stop losing bookings to slow replies",
    desc: "If a client has to wait for a DM response, they can book somewhere else. Boka lets them act while they are ready.",
  },
  {
    icon: TrendingUp,
    title: "Grow repeat revenue",
    desc: "Marketing emails, reminders and clearer customer journeys help more clients come back instead of drifting away after one visit.",
  },
];

const features = [
  {
    icon: CalendarCheck,
    title: "Online booking",
    desc: "Let clients book appointments from a mobile-friendly booking site without calling or messaging back and forth.",
  },
  {
    icon: CreditCard,
    title: "Online payments",
    desc: "Get paid online, no cash transaction needed.",
  },
  {
    icon: BadgePoundSterling,
    title: "Financial dashboard",
    desc: "Track revenue, services, and appointment activity from a simple business view built for day-to-day decisions.",
  },
  {
    icon: Globe,
    title: "Hand crafted personal websites",
    desc: "Give your brand a polished website that is connected to your services, staff, and booking flow.",
  },
  {
    icon: Users,
    title: "Staff management",
    desc: "Manage availability, working hours, appointments, and service ownership from one place.",
  },
  {
    icon: Bell,
    title: "Automated alerts",
    desc: "Send appointment reminders and updates by SMS or email to reduce admin work and missed appointments.",
  },
];

const testimonials = [
  {
    quote:
      "Boka has completely streamlined our booking process and given my business a new breath of life. The team at Boka have been very accommodating and helpful.",
    name: "Ali",
    role: "Owner, Ali's Barber",
  },
  {
    quote:
      "The automated reminders have significantly reduced our no-shows. It's a game changer for my business.",
    name: "Sylwia Cieleszynska",
    role: "Owner, sc_aesthetics_uk",
  },
  {
    quote:
      "We used to lose appointments when we were busy with clients. Now people can book from their phone and we see the appointment straight away.",
    name: "Marcus",
    role: "Founder, Northside Grooming",
  },
  {
    quote:
      "The website made us look more established, but the real win was how quickly people started booking without messaging first.",
    name: "Amira",
    role: "Owner, Glow Room Studio",
  },
  {
    quote:
      "Having availability, payments, and reminders connected has made the week feel much less chaotic for our team.",
    name: "Daniel",
    role: "Manager, Cut & Co.",
  },
  {
    quote:
      "Boka helped us turn Instagram interest into actual bookings. Clients tap through, choose a service, and pick a time without waiting on us.",
    name: "Priya",
    role: "Owner, Lash Lab",
  },
];

const testimonialLoop = [...testimonials, ...testimonials];

const faqItems = [
  {
    question: "Who is Boka built for?",
    answer:
      "Boka is built for barbers, salons, aesthetics clinics, and beauty professionals who want clients to book online, pay easily, and receive reminders without extra admin.",
  },
  {
    question: "Can clients book appointments themselves?",
    answer:
      "Yes. Boka gives clients a mobile-friendly booking flow where they can choose services, times, and staff availability without needing to call or message first.",
  },
  {
    question: "Do you support online payments?",
    answer:
      "Yes. Boka supports Stripe-powered online payments, including upfront payment flows and pay-in-store options depending on how you want to run the business.",
  },
  {
    question: "Will Boka help with no-shows?",
    answer:
      "Boka includes automated SMS and email reminders so clients get appointment prompts before they are due to arrive.",
  },
  {
    question: "Do I get a custom website?",
    answer:
      "The Starter plan includes a custom website and hosting. Growth adds the booking system, payments, notifications, analytics, and appointment management.",
  },
  {
    question: "What is SEO?",
    answer:
      "Search Engine Optimisation (SEO) ranks your business on a Google search and maps, Boka specialises in this to ensure you rank highly, especially compared to website builders, ensuring you rank well above competitors.",
  },
  {
    question: "Is there a free trial?",
    answer:
      "Yes. You can start with a free 1 month trial. No credit card is needed to begin the conversation.",
  },
];
---

<Layout
  title={siteConfig.meta.title}
  description={siteConfig.meta.description}
  keywords={siteConfig.meta.keywords}
>
  <HeroSection />

  <section
    class="site-container py-12 md:py-16"
    data-aos="fade-up-xs"
    data-aos-once="true"
    data-aos-delay="650"
  >
    <div class="grid grid-cols-2 gap-3 md:grid-cols-4">
      {
        proofPoints.map((item) => (
          <div class="rounded-xl border border-dashed border-primary/20 bg-bg-secondary px-4 py-5 text-center dark:border-neutral-700 dark:bg-bg-secondary-dark">
            <p class="font-brand text-3xl text-neutral-800 dark:text-neutral-100">
              {item.value}
            </p>
            <p class="mt-1 text-xs font-medium uppercase tracking-[0.14em] text-neutral-400 dark:text-neutral-500">
              {item.label}
            </p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="site-container py-16 md:py-24">
    <SectionHeader
      title="The booking workflow should not be the thing slowing you down"
      description="Boka is designed around the daily problems service businesses actually feel: missed bookings, no-shows, messy availability, and unclear revenue."
    />
    <div class="mt-8 grid grid-cols-1 gap-6 md:grid-cols-3">
      {
        problems.map((problem, i) => (
          <div
            class="rounded-xl border border-primary/10 bg-bg-secondary p-6 dark:border-neutral-700 dark:bg-bg-secondary-dark"
            data-aos="fade-up-sm"
            data-aos-delay={i * 100}
            data-aos-once="true"
          >
            <problem.icon class="mb-4 h-8 w-8 text-primary" />
            <h3 class="mb-2 text-lg font-semibold text-neutral-800 dark:text-neutral-100">
              {problem.title}
            </h3>
            <p class="text-sm leading-relaxed text-neutral-500 dark:text-neutral-400">
              {problem.desc}
            </p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="site-container py-16 md:py-24">
    <div class="grid items-start gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:gap-16">
      <div data-aos="fade-up-sm" data-aos-once="true">
        <p
          class="mb-4 inline-flex items-center gap-2 rounded-full border border-primary/15 bg-primary/5 px-3 py-1 text-xs font-medium text-primary"
        >
          <TrendingUp size={14} />
          Why you need Boka
        </p>
        <h2
          class="font-brand text-3xl leading-tight text-neutral-800 dark:text-neutral-100 md:text-5xl"
        >
          Every missed click, call, and reminder costs more than it looks.
        </h2>
        <p class="mt-5 leading-8 text-neutral-600 dark:text-neutral-300">
          Clients do not always book during opening hours. They search locally,
          compare quickly, and choose the business that makes the next step
          easiest. Without Boka, you can lose bookings before you even know
          someone was interested.
        </p>
        <div
          class="mt-7 rounded-2xl border border-dashed border-primary/20 bg-bg-secondary p-5 dark:border-neutral-700 dark:bg-bg-secondary-dark"
        >
          <p
            class="text-sm font-semibold text-neutral-800 dark:text-neutral-100"
          >
            Boka helps you look more credible, capture more intent, reduce
            admin, and give clients fewer reasons to choose someone else.
          </p>
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        {
          whyBokaMatters.map((item, i) => (
            <div
              class="rounded-xl border border-primary/10 bg-bg-secondary p-5 dark:border-neutral-700 dark:bg-bg-secondary-dark"
              data-aos="fade-up-sm"
              data-aos-delay={i * 100}
              data-aos-once="true"
            >
              <item.icon class="mb-4 h-7 w-7 text-primary" />
              <h3 class="mb-2 text-base font-semibold text-neutral-800 dark:text-neutral-100">
                {item.title}
              </h3>
              <p class="text-sm leading-relaxed text-neutral-500 dark:text-neutral-400">
                {item.desc}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <div
    class="my-4 w-full border-b border-dashed border-neutral-200 site-container dark:border-neutral-700"
  >
  </div>

  <section class="site-container py-16 md:py-24">
    <SectionHeader
      title="All you need in one place"
      description="Boka combines the public booking experience your clients need with the management tools your business depends on."
    />
    <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        features.map((feature, i) => (
          <div
            class="h-full"
            data-aos="fade-up-sm"
            data-aos-delay={i * 100}
            data-aos-once="true"
          >
            <div class="h-full rounded-xl border border-primary/10 bg-bg-secondary p-6 transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-md dark:border-neutral-700 dark:bg-bg-secondary-dark">
              <feature.icon class="mb-4 h-8 w-8 text-primary" />
              <h3 class="mb-2 text-lg font-semibold text-neutral-800 dark:text-neutral-100">
                {feature.title}
              </h3>
              <p class="text-sm leading-relaxed text-neutral-500 dark:text-neutral-400">
                {feature.desc}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section
    class="site-container py-16 md:py-24"
    data-aos="fade-up-sm"
    data-aos-once="true"
  >
    <SectionHeader
      title="A clear business dashboard"
      description="Monitor bookings, revenue, and operational activity from one place so the business is easier to run between appointments."
    />
    <div class="mx-auto mt-8 max-w-5xl">
      <BrowserFrame url="boka.app/dashboard">
        <img
          src="/assets/boka/boka-dashboard.png"
          alt="Boka dashboard showing appointments, revenue, and business analytics"
          loading="lazy"
          width="1280"
          height="1044"
          class="h-[360px] w-full object-cover object-top md:h-[520px]"
        />
      </BrowserFrame>
    </div>
  </section>

  <section class="site-container py-16 md:py-24">
    <div class="grid items-center gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:gap-16">
      <div data-aos="fade-up-sm" data-aos-once="true">
        <p
          class="mb-4 inline-flex items-center gap-2 rounded-full border border-primary/15 bg-primary/5 px-3 py-1 text-xs font-medium text-primary"
        >
          <Scissors size={14} />
          Client booking site
        </p>
        <h2
          class="font-brand text-3xl leading-tight text-neutral-800 dark:text-neutral-100 md:text-5xl"
        >
          A website that turns visits into appointments.
        </h2>
        <p class="mt-5 leading-8 text-neutral-600 dark:text-neutral-300">
          Your website should show your brand, services, and availability
          without making clients work for the next step. Boka keeps the booking
          action close to the content.
        </p>
        <ul class="mt-6 space-y-3">
          {
            [
              "Service-led pages",
              "Mobile-friendly appointment flow",
              "Connected to availability and payments",
            ].map((point) => (
              <li class="flex items-start gap-2">
                <CircleCheck class="mt-0.5 h-4 w-4 flex-shrink-0 text-primary" />
                <span class="text-sm text-neutral-600 dark:text-neutral-300">
                  {point}
                </span>
              </li>
            ))
          }
        </ul>
      </div>

      <div data-aos="fade-up-sm" data-aos-delay="150" data-aos-once="true">
        <BrowserFrame url="alisbarber.boka.app">
          <img
            src="/assets/boka/barber-website.jpg"
            alt="Example barber booking website built with Boka"
            loading="lazy"
            width="1024"
            height="1024"
            class="h-[420px] w-full object-cover object-top md:h-[520px]"
          />
        </BrowserFrame>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24">
    <div class="site-container">
      <SectionHeader
        title="Success stories from clients"
        description="Early Boka users are already using the platform to simplify bookings, reduce missed appointments, and turn online interest into real visits."
      />
    </div>

    <div class="site-container mt-8 grid grid-cols-1 gap-6 md:hidden">
      {
        testimonials.map((item, i) => (
          <figure
            class="rounded-xl border border-primary/10 bg-bg-secondary p-6 dark:border-neutral-700 dark:bg-bg-secondary-dark"
            data-aos="fade-up-sm"
            data-aos-delay={i * 80}
            data-aos-once="true"
          >
            <MessageCircle class="mb-4 h-6 w-6 text-primary" />
            <blockquote class="text-sm leading-7 text-neutral-600 dark:text-neutral-300">
              "{item.quote}"
            </blockquote>
            <figcaption class="mt-5 border-t border-dashed border-neutral-200 pt-4 dark:border-neutral-700">
              <p class="font-semibold text-neutral-800 dark:text-neutral-100">
                {item.name}
              </p>
              <p class="text-sm text-neutral-500 dark:text-neutral-400">
                {item.role}
              </p>
            </figcaption>
          </figure>
        ))
      }
    </div>

    <div
      class="testimonial-marquee mt-8 hidden overflow-hidden md:block"
      data-aos="fade-up-sm"
      data-aos-once="true"
    >
      <div class="testimonial-track flex w-max gap-6 px-4">
        {
          testimonialLoop.map((item) => (
            <figure class="testimonial-card w-[360px] shrink-0 rounded-xl border border-primary/10 bg-bg-secondary p-6 dark:border-neutral-700 dark:bg-bg-secondary-dark">
              <MessageCircle class="mb-4 h-6 w-6 text-primary" />
              <blockquote class="text-sm leading-7 text-neutral-600 dark:text-neutral-300">
                "{item.quote}"
              </blockquote>
              <figcaption class="mt-5 border-t border-dashed border-neutral-200 pt-4 dark:border-neutral-700">
                <p class="font-semibold text-neutral-800 dark:text-neutral-100">
                  {item.name}
                </p>
                <p class="text-sm text-neutral-500 dark:text-neutral-400">
                  {item.role}
                </p>
              </figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <Pricing />

  <div
    class="my-4 w-full border-b border-dashed border-neutral-200 site-container dark:border-neutral-700"
  >
  </div>

  <FAQ title="Frequently asked questions" items={faqItems} />

  <section
    class="mt-8 bg-bg-secondary py-16 dark:bg-bg-secondary-dark md:py-24"
    data-aos="fade-up-xs"
    data-aos-once="true"
  >
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2
        class="mb-4 font-brand text-3xl text-neutral-800 dark:text-neutral-100 md:text-4xl"
      >
        Start your free 1 month trial
      </h2>
      <p class="mb-8 leading-relaxed text-neutral-600 dark:text-neutral-300">
        See how Boka can fit your services, staff, payments, and client booking
        flow before you commit.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <Button
          url={siteConfig.links.trial}
          type="fill"
          className="px-8 py-3 text-lg"
        >
          Start free trial <ArrowRight size={18} />
        </Button>
        <Button
          url={siteConfig.links.dashboardDemo}
          className="px-8 py-3 text-lg"
          target="_blank"
        >
          View dashboard
        </Button>
      </div>
    </div>
  </section>
</Layout>

<style>
  .testimonial-marquee {
    mask-image: linear-gradient(
      to right,
      transparent,
      black 10%,
      black 90%,
      transparent
    );
  }

  .testimonial-track {
    animation: testimonial-scroll 42s linear infinite;
  }

  .testimonial-marquee:hover .testimonial-track {
    animation-play-state: paused;
  }

  .testimonial-card {
    min-height: 250px;
  }

  @keyframes testimonial-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(calc(-50% - 0.75rem));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .testimonial-track {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
      width: auto;
    }

    .testimonial-marquee {
      mask-image: none;
    }
  }
</style>
