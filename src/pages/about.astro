---
import Layout from "@/layouts/Layout.astro";
import PageHeader from "@/components/elements/PageHeader.astro";
import Button from "@/components/ui/Button.astro";
import Badge from "@/components/ui/Badge.astro";
import { siteConfig } from "@/config/site";
import { ArrowRight, CalendarCheck, ChartNoAxesColumnIncreasing, LifeBuoy, Users } from "@lucide/astro";

const timeline = [
  {
    version: "01",
    date: "Problem",
    title: "Too many service businesses still run bookings manually",
    desc: "Barbers, salons, and beauty professionals often rely on messages, calls, spreadsheets, and disconnected payment tools.",
  },
  {
    version: "02",
    date: "Build",
    title: "Boka brings the workflow into one place",
    desc: "The platform combines a custom website, online booking, payments, reminders, staff availability, and reporting.",
  },
  {
    version: "03",
    date: "Pilot",
    title: "Early businesses use Boka to reduce admin",
    desc: "Client feedback has focused on smoother booking, fewer no-shows, and clearer business visibility.",
  },
  {
    version: "04",
    date: "Next",
    title: "A calmer operating system for local services",
    desc: "The roadmap stays focused on the tools owners use every week: appointments, reminders, payments, staff, and growth insights.",
  },
];

const values = [
  {
    icon: CalendarCheck,
    title: "Practical booking first",
    desc: "The product starts with the appointment flow because that is where clients and revenue meet.",
  },
  {
    icon: Users,
    title: "Built around real teams",
    desc: "Staff availability, services, and working patterns need to fit the business rather than force a generic setup.",
  },
  {
    icon: ChartNoAxesColumnIncreasing,
    title: "Clear owner visibility",
    desc: "Owners should understand bookings and revenue without needing to build their own reporting stack.",
  },
  {
    icon: LifeBuoy,
    title: "Hands-on setup",
    desc: "Boka is meant to be adopted by busy local businesses, so setup support matters as much as the software.",
  },
];
---

<Layout
  title="About - Boka"
  description="Boka helps barbers, salons, and beauty professionals manage bookings, payments, reminders, websites, staff, and business insights."
>
  <section class="site-container my-12">
    <PageHeader
      title="Built for the businesses that run on appointments"
      description="Boka exists to help local service businesses get booked, get paid, and grow without stitching together a dozen separate tools."
    />
  </section>

  <section class="site-container mx-auto max-w-3xl pb-24">
    <article class="space-y-10">
      <div data-aos="fade-up-xs" data-aos-once="true">
        <h2 class="mb-4 font-brand text-2xl text-neutral-800 dark:text-neutral-100">Why Boka exists</h2>
        <div class="space-y-4 leading-relaxed text-neutral-600 dark:text-neutral-300">
          <p>
            Appointment-led businesses have a lot happening at once: clients asking for times, staff availability changing, payments to chase, no-shows to reduce, and a website that should bring in new bookings rather than just sit online.
          </p>
          <p>
            Boka brings those pieces together. A client can discover the business, choose a service, book a slot, and pay through a clean online flow. The owner gets a dashboard for appointments, revenue, staff, and business activity.
          </p>
          <p>
            The goal is not to add more software for owners to manage. It is to make the operating rhythm simpler, clearer, and easier to grow.
          </p>
        </div>
      </div>

      <div class="w-full border-b border-dashed border-neutral-200 dark:border-neutral-700"></div>

      <div data-aos="fade-up-xs" data-aos-delay="100" data-aos-once="true">
        <h2 class="mb-6 font-brand text-2xl text-neutral-800 dark:text-neutral-100">What we care about</h2>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          {values.map(({ icon: Icon, title, desc }) => (
            <div class="rounded-xl border border-primary/10 bg-bg-secondary p-5 dark:border-neutral-700 dark:bg-bg-secondary-dark">
              <Icon class="mb-3 h-5 w-5 text-primary" />
              <h3 class="mb-1 text-sm font-semibold text-neutral-800 dark:text-neutral-100">{title}</h3>
              <p class="text-sm text-neutral-500 dark:text-neutral-400">{desc}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="w-full border-b border-dashed border-neutral-200 dark:border-neutral-700"></div>

      <div data-aos="fade-up-xs" data-aos-delay="100" data-aos-once="true">
        <h2 class="mb-6 font-brand text-2xl text-neutral-800 dark:text-neutral-100">How we think about the product</h2>
        <div class="relative">
          <div class="absolute bottom-1.5 left-3 top-1.5 w-px bg-neutral-200 dark:bg-neutral-700 md:left-4"></div>
          <ol class="space-y-8">
            {timeline.map((item, i) => (
              <li class="relative pl-10 md:pl-12" data-aos="fade-up-sm" data-aos-delay={i * 80} data-aos-once="true">
                <div class="absolute left-1.5 top-1.5 h-3 w-3 rounded-full border-2 border-bg-primary bg-primary dark:border-bg-primary-dark md:left-2.5"></div>
                <div class="mb-1 flex flex-wrap items-center gap-3">
                  <Badge variant="primary" size="sm">{item.version}</Badge>
                  <span class="text-xs text-neutral-400 dark:text-neutral-500">{item.date}</span>
                </div>
                <h3 class="mb-1 text-base font-semibold text-neutral-800 dark:text-neutral-100">{item.title}</h3>
                <p class="text-sm leading-relaxed text-neutral-500 dark:text-neutral-400">{item.desc}</p>
              </li>
            ))}
          </ol>
        </div>
      </div>

      <div class="w-full border-b border-dashed border-neutral-200 dark:border-neutral-700"></div>

      <div data-aos="fade-up-xs" data-aos-delay="100" data-aos-once="true">
        <h2 class="mb-4 font-brand text-2xl text-neutral-800 dark:text-neutral-100">Talk to Boka</h2>
        <p class="mb-6 leading-relaxed text-neutral-600 dark:text-neutral-300">
          If you run a service business and want to move bookings, payments, reminders, and your website into one place, we can help you map the right setup.
        </p>
      </div>

      <div class="flex flex-wrap gap-4" data-aos="fade-up-xs" data-aos-delay="200" data-aos-once="true">
        <Button url={siteConfig.links.trial} type="fill">
          Start free trial <ArrowRight size={16} />
        </Button>
        <Button url="/pricing">
          View pricing
        </Button>
      </div>
    </article>
  </section>
</Layout>
